{
  "name": "baraaq",
  "version": "1.0.10",
  "main": "main.js",
  "description": "Hash POS Desktop — نظام نقاط البيع المتكامل للمطاعم (Techier)",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "start": "electron .",
    "start:sim-print": "electron . --simulate-thermal-print",
    "start:sim-print-open": "electron . --simulate-thermal-print --simulate-thermal-print-open",
    "test:print-sim": "electron scripts/print-sim-smoke.js",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.hash.pos",
    "productName": "Hash POS Desktop",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!**/*.map",
      "!.git/**/*",
      "!dist/**/*",
      "!node_modules/puppeteer/.local-chromium/**/*"
    ],
    "extraResources": [
      {
        "from": "google-oauth.json",
        "to": "google-oauth.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "1111.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "playwright": "^1.50.1",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@phosphor-icons/web": "^2.1.2",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "googleapis": "^169.0.0",
    "html2canvas": "^1.4.1",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6",
    "zatca-xml-js": "^0.1.9"
  }
}
